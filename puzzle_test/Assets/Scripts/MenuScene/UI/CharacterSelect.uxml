    <ui:VisualElement name="root" class="root" style="flex-grow: 1; padding-top: 100px; padding-bottom: 100px; -unity-font: initial; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Noto_Sans_JP,WDXL_Lubrifont_JP_N/Noto_Sans_JP/static/NotoSansJP-Regular%20SDF.asset?fileID=11400000&amp;guid=b1dd9ab9795997e468bc17531bc4f5ad&amp;type=2#NotoSansJP-Regular SDF&quot;);">
